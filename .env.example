# ============================================================
# .env.example — Kalshi BTC Hourly Trader Bot
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Kalshi API credentials (required)
# ------------------------------------------------------------
# Your API key ID from https://kalshi.com/account/api-access
KALSHI_API_KEY_ID=your-api-key-id-here

# Absolute path to your RSA-2048 private key PEM file.
# Generate with: openssl genrsa -out private_key.pem 2048
# Then upload the public key to Kalshi's API access page.
KALSHI_PRIVATE_KEY_PATH=/path/to/private_key.pem

# ------------------------------------------------------------
# Environment (demo or prod)
# ------------------------------------------------------------
# Use 'demo' for paper trading. Only switch to 'prod' when
# you are fully confident in the bot's behavior.
KALSHI_ENV=demo

# ------------------------------------------------------------
# BTC Hourly market series ticker
# ------------------------------------------------------------
# Verify the correct ticker by calling:
#   GET /series  (look for BTC hourly series)
# Common values: KXBTCH, KXBTC1H
BTC_SERIES_TICKER_HOURLY=KXBTCH

# ------------------------------------------------------------
# Trading mode
# ------------------------------------------------------------
# Set to false ONLY when ready for live trading.
# While true, all orders are simulated and logged but NOT sent.
DRY_RUN=true

# ------------------------------------------------------------
# Risk limits
# ------------------------------------------------------------
# Exit position if loss exceeds this many cents
STOP_LOSS_CENTS=35

# Exit position if gain exceeds this many cents
TAKE_PROFIT_CENTS=22

# Exit position if held longer than this many minutes
MAX_HOLD_MINUTES=50

# Maximum dollars to risk in a single trade
MAX_DOLLARS_PER_TRADE=25

# Maximum number of concurrent open positions
MAX_OPEN_POSITIONS=3

# Maximum total dollar exposure across all positions (cents)
MAX_TOTAL_EXPOSURE_CENTS=7500

# Daily loss circuit breaker: halt trading if total loss exceeds this (cents)
MAX_DAILY_LOSS_CENTS=5000

# Maximum number of trades to place per calendar day (UTC)
MAX_DAILY_TRADES=20

# ------------------------------------------------------------
# Strategy parameters
# ------------------------------------------------------------
# Minimum signal confidence required to enter a trade (0.0 – 1.0)
MIN_CONFIDENCE=0.12

# Minimum net edge in cents after fees before entering a trade
MIN_EDGE_CENTS=3

# Skip markets where best_ask - best_bid > this many cents
MAX_SPREAD_CENTS=5

# Lookback window in hours for momentum/skew signals
LOOKBACK_HOURS=3

# Do not enter new trades if less than this many minutes remain to expiry
TIME_TO_EXPIRY_MIN_MINUTES=5

# Minimum percent price move (over LOOKBACK_HOURS) to fire a momentum signal
MOMENTUM_THRESHOLD=0.5

# How often the main loop polls for signals (seconds)
POLL_INTERVAL_SECONDS=60

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
# Path to the trade journal CSV file
TRADES_CSV_PATH=trades_hourly.csv

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Set to true for verbose debug-level logging
VERBOSE_LOGGING=false
